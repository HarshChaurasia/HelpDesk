generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CUSTOMER
  AGENT
  ADMIN
}

enum TicketStatus {
  NEW
  OPEN
  IN_PROGRESS
  PENDING_CUSTOMER
  RESOLVED
  CLOSED
  REOPENED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum MessageType {
  PUBLIC_REPLY
  INTERNAL_NOTE
}

enum Channel {
  WEB
  EMAIL
}

enum NotifChannelPref {
  IN_APP
  EMAIL
  BOTH
  OFF
}

enum EventType {
  CREATED
  STATUS_CHANGED
  ASSIGNED
  PRIORITY_CHANGED
  CATEGORY_CHANGED
  SUBCATEGORY_CHANGED
  TAG_ADDED
  TAG_REMOVED
  WATCHER_ADDED
  WATCHER_REMOVED
  MESSAGE_ADDED
  REOPENED
  CLOSED
  TIME_LOGGED
  DELIVERY_DATE_SET
  ESCALATED
  DE_ESCALATED
}

enum TimeLogType {
  INVESTIGATION
  DEVELOPMENT
  TESTING
  OTHER
}

model User {
  id           String           @id @default(uuid())
  email        String           @unique
  passwordHash String?
  fullName     String
  phone        String?
  organization String?
  role         Role             @default(CUSTOMER)
  isActive     Boolean          @default(true)
  notifPref    NotifChannelPref @default(BOTH)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  createdTickets  Ticket[]         @relation("CreatedBy")
  assignedTickets Ticket[]         @relation("AssignedTo")
  ticketAssignees TicketAssignee[] @relation("TicketAssignees")
  watching        TicketWatcher[]
  messages        Message[]
  events          TicketEvent[]
  notifications   Notification[]
  refreshTokens   RefreshToken[]
  resetTokens     PasswordResetToken[]
  reactions       Reaction[]       @relation("UserReactions")
  timeLogs        TicketTimeLog[]  @relation("TimeLogUser")
  ccAdded         TicketCC[]       @relation("CCAddedBy")
  savedViews      SavedView[]
  escalations     Escalation[]     @relation("EscalatedBy")
  changeRequests  ChangeRequest[]  @relation("ChangeRequestCreator")
}

model SlaPolicy {
  id             String     @id @default(uuid())
  name           String     @unique
  responseMins   Json
  resolutionMins Json
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  categories     Category[]
}

model Category {
  id            String        @id @default(uuid())
  name          String        @unique
  description   String?
  slaPolicyId   String?
  slaPolicy     SlaPolicy?    @relation(fields: [slaPolicyId], references: [id])
  isActive      Boolean       @default(true)
  tickets       Ticket[]
  subcategories Subcategory[]
}

model Subcategory {
  id         String   @id @default(uuid())
  name       String
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  isActive   Boolean  @default(true)
  tickets    Ticket[]
  createdAt  DateTime @default(now())

  @@unique([categoryId, name])
  @@index([categoryId])
}

model Tag {
  id        String      @id @default(uuid())
  name      String      @unique
  color     String      @default("#6366f1")
  tickets   TicketTag[]
  createdAt DateTime    @default(now())
}

model TicketTag {
  ticketId String
  ticket   Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  tagId    String
  tag      Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([ticketId, tagId])
  @@index([ticketId])
}

enum ChangeRequestStatus {
  PENDING
  APPROVED
  REJECTED
  IMPLEMENTED
}

model ChangeRequest {
  id            String              @id @default(uuid())
  ticketId      String              @unique
  ticket        Ticket              @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  title         String
  description   String?
  impact        String?
  rollbackPlan  String?
  scheduledAt   DateTime?
  status        ChangeRequestStatus @default(PENDING)
  createdById   String
  createdBy     User                @relation("ChangeRequestCreator", fields: [createdById], references: [id])
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
}

model Escalation {
  id             String    @id @default(uuid())
  ticketId       String    @unique
  ticket         Ticket    @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  escalatedById  String
  escalatedBy    User      @relation("EscalatedBy", fields: [escalatedById], references: [id])
  level          Int       @default(1)
  reason         String
  resolvedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model SavedView {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  filters   Json
  createdAt DateTime @default(now())

  @@unique([userId, name])
  @@index([userId])
}

model TicketFeedback {
  id          String   @id @default(uuid())
  ticketId    String   @unique
  ticket      Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  rating      Int
  comment     String?
  submittedAt DateTime @default(now())
}

model TicketRelation {
  id        String   @id @default(uuid())
  ticketId  String
  ticket    Ticket   @relation("TicketRelations", fields: [ticketId], references: [id], onDelete: Cascade)
  relatedId String
  related   Ticket   @relation("RelatedTickets", fields: [relatedId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([ticketId, relatedId])
  @@index([ticketId])
}

model TicketCC {
  id        String   @id @default(uuid())
  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  email     String
  addedById String?
  addedBy   User?    @relation("CCAddedBy", fields: [addedById], references: [id])
  addedAt   DateTime @default(now())

  @@unique([ticketId, email])
  @@index([ticketId])
}

model TicketTimeLog {
  id        String      @id @default(uuid())
  ticketId  String
  ticket    Ticket      @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  userId    String
  user      User        @relation("TimeLogUser", fields: [userId], references: [id])
  type      TimeLogType
  hours     Float
  billable  Boolean     @default(true)
  note      String?
  loggedAt  DateTime    @default(now())

  @@index([ticketId])
}

model Ticket {
  id                     String       @id @default(uuid())
  reference              String       @unique
  subject                String
  status                 TicketStatus @default(NEW)
  priority               Priority     @default(MEDIUM)
  channel                Channel      @default(WEB)
  categoryId             String?
  category               Category?    @relation(fields: [categoryId], references: [id])
  subcategoryId          String?
  subcategory            Subcategory? @relation(fields: [subcategoryId], references: [id])
  createdById            String
  createdBy              User         @relation("CreatedBy", fields: [createdById], references: [id])
  assignedToId           String?
  assignedTo             User?        @relation("AssignedTo", fields: [assignedToId], references: [id])
  deliveryDate           DateTime?
  estimatedEffortHours   Float?
  resolutionSummary      String?
  rootCause              String?
  correctiveAction       String?
  preventiveAction       String?
  systemProduct          String?
  systemModule           String?
  systemVersion          String?
  systemBrowser          String?
  systemOs               String?
  noAutoClose            Boolean      @default(false)
  firstResponseAt        DateTime?
  resolvedAt             DateTime?
  closedAt               DateTime?
  slaResponseDueAt       DateTime?
  slaResolutionDueAt     DateTime?
  slaBreached            Boolean      @default(false)
  lastCustomerActivityAt DateTime     @default(now())
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt

  watchers      TicketWatcher[]
  assignees     TicketAssignee[]
  messages      Message[]
  events        TicketEvent[]
  attachments   Attachment[]
  notifications Notification[]
  tags          TicketTag[]
  timeLogs      TicketTimeLog[]
  ccRecipients   TicketCC[]
  feedback       TicketFeedback?
  escalation     Escalation?
  changeRequest  ChangeRequest?
  relations      TicketRelation[] @relation("TicketRelations")
  relatedTo      TicketRelation[] @relation("RelatedTickets")

  @@index([status])
  @@index([assignedToId, status])
  @@index([categoryId])
  @@index([subcategoryId])
  @@index([createdById])
  @@index([createdAt])
}

model TicketWatcher {
  ticketId String
  ticket   Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  userId   String
  user     User     @relation(fields: [userId], references: [id])
  addedAt  DateTime @default(now())

  @@id([ticketId, userId])
}

model TicketAssignee {
  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation("TicketAssignees", fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([ticketId, userId])
  @@index([ticketId])
}

model Message {
  id              String      @id @default(uuid())
  ticketId        String
  ticket          Ticket      @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  authorId        String?
  author          User?       @relation(fields: [authorId], references: [id])
  type            MessageType @default(PUBLIC_REPLY)
  body            String
  channel         Channel     @default(WEB)
  sourceMessageId String?
  editedAt        DateTime?
  deletedAt       DateTime?
  createdAt       DateTime    @default(now())
  attachments     Attachment[]
  reactions       Reaction[]

  @@index([ticketId, createdAt])
}

model Reaction {
  id        String   @id @default(uuid())
  messageId String
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation("UserReactions", fields: [userId], references: [id], onDelete: Cascade)
  emoji     String
  createdAt DateTime @default(now())

  @@unique([messageId, userId, emoji])
  @@index([messageId])
}

model Attachment {
  id           String   @id @default(uuid())
  ticketId     String?
  ticket       Ticket?  @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  messageId    String?
  message      Message? @relation(fields: [messageId], references: [id], onDelete: Cascade)
  fileName     String
  mimeType     String
  sizeBytes    Int
  storageKey   String
  uploadedById String?
  createdAt    DateTime @default(now())
}

model TicketEvent {
  id        String    @id @default(uuid())
  ticketId  String
  ticket    Ticket    @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  actorId   String?
  actor     User?     @relation(fields: [actorId], references: [id])
  type      EventType
  fromValue String?
  toValue   String?
  metadata  Json?
  createdAt DateTime  @default(now())

  @@index([ticketId, createdAt])
}

model Notification {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  ticketId    String?
  ticket      Ticket?   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  eventType   EventType
  title       String
  body        String
  isRead      Boolean   @default(false)
  emailSentAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([userId, isRead, createdAt])
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  tokenHash String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  tokenHash String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
}

model ProcessedEmail {
  id               String   @id @default(uuid())
  messageId        String   @unique
  ticketId         String?
  createdMessageId String?
  outcome          String
  processedAt      DateTime @default(now())
}

model Counter {
  name  String @id
  value Int    @default(0)
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

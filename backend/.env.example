NODE_ENV=development
PORT=3000

DATABASE_URL="postgresql://helpdesk:helpdesk@localhost:5432/helpdesk?schema=public"

JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

CORS_ORIGIN=http://localhost:5173

# Outbound email (MailHog in dev)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM="Help Desk <support@helpdesk.local>"

# Inbound email (IMAP polling). Disabled by default in dev.
IMAP_ENABLED=false
IMAP_HOST=
IMAP_PORT=993
IMAP_SECURE=true
IMAP_USER=
IMAP_PASS=
IMAP_POLL_CRON=*/1 * * * *

# Business rules
AUTO_CLOSE_DAYS=5
UPLOAD_DIR=./uploads
MAX_UPLOAD_BYTES=10485760
